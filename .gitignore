# ignore all hidden
.*
# except
!.gitattributes
!.gitignore
!.gitmodules
!.github
!.github/**
!.yamlfmt.yaml
!.yamllint.yml

# Logs
logs
*.log*

*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# AI tools
!.serena
!.claude
!.taskmaster

# Secret Management (Phase)
# Environment files with actual secrets
.env
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local

# Keep example/template files
!.env.example
!.env.template

# Credential files
*credentials*.json
*secrets*.json
*secret*.yaml
*secret*.yml

# Phase credentials (user-level service token — never commit)
.phase/config.json

# .phase.json (project-app link) IS safe to commit — no credentials inside
# Uncomment below only if you want to keep it local:
# .phase.json

# API keys and tokens
*.key
*.pem
!*_example.key
!*_example.pem
